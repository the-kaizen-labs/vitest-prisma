{
  "name": "vitest-prisma",
  "version": "1.0.1",
  "description": "Vitest environment for Prisma designed for fast integration tests: seed your database once with production-like data, then run each test in a transaction that is rolled back after execution. Tests remain isolated without expensive reseeding.",
  "keywords": [
    "prisma",
    "prisma orm",
    "test",
    "test isolation",
    "testing",
    "transaction",
    "vitest"
  ],
  "license": "MIT",
  "author": "Christoph Werner <christoph@codepunkt.de>",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-kaizen-labs/vitest-prisma"
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./setup": {
      "import": "./dist/setup.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "changeset": "changeset",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "release": "pnpm run build && changeset publish",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "version": "changeset version && pnpm install --lockfile-only"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@prisma/adapter-pg": "7.2.0",
    "@types/node": "24.10.4",
    "@vitest/coverage-v8": "4.0.16",
    "husky": "9.1.7",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "prisma": "7.2.0",
    "tsdown": "0.21.7",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  },
  "peerDependencies": {
    "@prisma/adapter-pg": ">=4 <8",
    "prisma": ">=4 <8",
    "vitest": ">=4 <5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.27.0"
}
